# Copy to .env and fill for local overrides. In production (Render/Railway) set these in the dashboard.

# PostgreSQL connection string (optional; has default for local)
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Comma-separated frontend URLs to allow CORS (add your Vercel/Netlify URL after deploy)
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app.netlify.app
